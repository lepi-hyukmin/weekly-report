  "scripts": {
    "start": "nx serve",
    "build": "nx build",
    "test": "nx test",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently \"nx serve\" \"wait-on http://localhost:4200 && npm run build:electron && electron dist/weekly-report/electron/main.js --dev\"",
    "electron:build": "nx build --configuration=production && npm run build:electron",
    "electron:package": "npm run electron:build && electron-builder --config electron-builder.json --win --x64"
  },
